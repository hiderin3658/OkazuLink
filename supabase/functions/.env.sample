# supabase/functions/.env のサンプル。
# 実ファイルは Git ignore 済（リポ root の .gitignore で `.env` パターン）。
#
# ローカル開発時:
#   cp supabase/functions/.env.sample supabase/functions/.env
#   実値を埋めて `supabase functions serve --env-file ./supabase/functions/.env`
#
# 本番（Supabase Edge Function secrets）:
#   supabase secrets set GEMINI_API_KEY=xxx
#
# Note: SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY は
# `supabase functions serve` 起動時に自動注入されるため本ファイルでは不要。
# CORS / コスト管理 (ALLOWED_ORIGIN, MONTHLY_AI_BUDGET_JPY, AI_BUDGET_MODE,
# USD_JPY_RATE) も将来必要になった時点で追加する。

# =============================================================================
# Gemini API
# =============================================================================
# Google AI Studio (https://aistudio.google.com/apikey) で発行
GEMINI_API_KEY=

# モデル指定（環境変数で差し替え可能。設計書 §9.1 参照）
# 未設定の場合、各 Edge Function のデフォルト値が使われる
MODEL_OCR=gemini-3-flash
MODEL_OCR_FALLBACK=gemini-3-pro
MODEL_RECIPE=gemini-3-flash
MODEL_ADVICE=gemini-3-pro
MODEL_REPORT=gemini-3.1-flash-lite
