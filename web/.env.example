# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini AI (Edge Function 側で使用、クライアントには渡さない)
# Supabase Edge Function の環境変数として設定すること
# GEMINI_API_KEY=your-gemini-api-key

# AI モデル切替（Edge Function 側）
# MODEL_OCR=gemini-3-flash
# MODEL_OCR_FALLBACK=gemini-3-pro
# MODEL_RECIPE=gemini-3-flash
# MODEL_ADVICE=gemini-3-pro
# MODEL_REPORT=gemini-3.1-flash-lite

# コスト管理
# MONTHLY_AI_BUDGET_JPY=1000
# AI_BUDGET_MODE=soft  # soft=警告のみ, hard=超過時停止
